{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://app-spec.ai/spec/v0.1/app.schema.json",
  "type": "object",
  "properties": {
    "apiVersion": {
      "$ref": "#/$defs/ApiVersion"
    },
    "kind": {
      "$ref": "#/$defs/AppKind"
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "spec": {
      "$ref": "#/$defs/AppSpec"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "additionalProperties": false,
  "title": "AI App Manifest",
  "description": "An AI App Spec version 0.1 manifest.",
  "$defs": {
    "ApiVersion": {
      "type": "string",
      "const": "app-spec.ai/v0.1"
    },
    "AppKind": {
      "type": "string",
      "const": "App"
    },
    "Metadata": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "#/$defs/Identifier"
        },
        "version": {
          "$ref": "#/$defs/SemanticVersion"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "name",
        "version"
      ],
      "additionalProperties": false
    },
    "Identifier": {
      "type": "string",
      "maxLength": 63,
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "SemanticVersion": {
      "type": "string",
      "maxLength": 255,
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "AppSpec": {
      "type": "object",
      "properties": {
        "entrypoint": {
          "$ref": "#/$defs/Identifier"
        },
        "requirements": {
          "$ref": "#/$defs/Requirements"
        },
        "resources": {
          "minItems": 1,
          "type": "array",
          "items": {
            "$ref": "#/$defs/Resource"
          }
        }
      },
      "required": [
        "entrypoint",
        "resources"
      ],
      "additionalProperties": false
    },
    "Requirements": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "secrets": {
              "minItems": 1,
              "type": "array",
              "items": {
                "$ref": "#/$defs/SecretRequirement"
              }
            },
            "executionEnvironments": {
              "minItems": 1,
              "type": "array",
              "items": {
                "$ref": "#/$defs/ExecutionEnvironmentRequirement"
              }
            }
          },
          "required": [
            "secrets"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "secrets": {
              "minItems": 1,
              "type": "array",
              "items": {
                "$ref": "#/$defs/SecretRequirement"
              }
            },
            "executionEnvironments": {
              "minItems": 1,
              "type": "array",
              "items": {
                "$ref": "#/$defs/ExecutionEnvironmentRequirement"
              }
            }
          },
          "required": [
            "executionEnvironments"
          ],
          "additionalProperties": false
        }
      ]
    },
    "SecretRequirement": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/Identifier"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "id"
      ],
      "additionalProperties": false
    },
    "ExecutionEnvironmentRequirement": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/Identifier"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "id"
      ],
      "additionalProperties": false
    },
    "Resource": {
      "oneOf": [
        {
          "$ref": "#/$defs/AgentResource"
        },
        {
          "$ref": "#/$defs/MCPServerResource"
        }
      ]
    },
    "AgentResource": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/Identifier"
        },
        "kind": {
          "type": "string",
          "const": "Agent"
        },
        "executionEnvironment": {
          "$ref": "#/$defs/ExecutionEnvironmentReference"
        },
        "tools": {
          "minItems": 1,
          "type": "array",
          "items": {
            "$ref": "#/$defs/ResourceReference"
          }
        },
        "implementation": {
          "$ref": "#/$defs/AgentImplementation"
        }
      },
      "required": [
        "id",
        "kind",
        "implementation"
      ],
      "additionalProperties": false
    },
    "ExecutionEnvironmentReference": {
      "type": "object",
      "properties": {
        "ref": {
          "$ref": "#/$defs/Identifier"
        }
      },
      "required": [
        "ref"
      ],
      "additionalProperties": false
    },
    "ResourceReference": {
      "type": "object",
      "properties": {
        "ref": {
          "$ref": "#/$defs/Identifier"
        }
      },
      "required": [
        "ref"
      ],
      "additionalProperties": false
    },
    "AgentImplementation": {
      "type": "object",
      "properties": {
        "format": {
          "$ref": "#/$defs/ImplementationFormat"
        },
        "package": {
          "$ref": "#/$defs/ImplementationPackage"
        }
      },
      "required": [
        "format",
        "package"
      ],
      "additionalProperties": false
    },
    "ImplementationFormat": {
      "type": "string",
      "maxLength": 255,
      "pattern": "^(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\/[a-z][a-z0-9]*(?:-[a-z0-9]+)*:v(?:0|[1-9]\\d*)(?:\\.(?:0|[1-9]\\d*)){0,2}$"
    },
    "ImplementationPackage": {
      "type": "object",
      "properties": {
        "location": {
          "$ref": "#/$defs/PackageLocation"
        },
        "digest": {
          "$ref": "#/$defs/Sha256Digest"
        }
      },
      "required": [
        "location",
        "digest"
      ],
      "additionalProperties": false
    },
    "PackageLocation": {
      "anyOf": [
        {
          "$ref": "#/$defs/PackageRelativeLocation"
        },
        {
          "$ref": "#/$defs/AbsolutePackageLocation"
        }
      ]
    },
    "PackageRelativeLocation": {
      "type": "string",
      "maxLength": 2048,
      "pattern": "^\\.\\/[A-Za-z0-9](?:[A-Za-z0-9._-]*[A-Za-z0-9])?(?:\\/[A-Za-z0-9](?:[A-Za-z0-9._-]*[A-Za-z0-9])?)*$"
    },
    "AbsolutePackageLocation": {
      "type": "string",
      "maxLength": 2048,
      "pattern": "^(?![Ff][Ii][Ll][Ee]:)(?![A-Za-z]:[\\\\/])[A-Za-z][A-Za-z0-9+.-]*:[^\\s\\\\]+$"
    },
    "Sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "MCPServerResource": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/Identifier"
        },
        "kind": {
          "type": "string",
          "const": "MCPServer"
        },
        "connection": {
          "$ref": "#/$defs/MCPServerConnection"
        },
        "authentication": {
          "$ref": "#/$defs/MCPServerAuthentication"
        }
      },
      "required": [
        "id",
        "kind",
        "connection"
      ],
      "additionalProperties": false
    },
    "MCPServerConnection": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "url"
        },
        "url": {
          "$ref": "#/$defs/MCPServerUrl"
        }
      },
      "required": [
        "type",
        "url"
      ],
      "additionalProperties": false
    },
    "MCPServerUrl": {
      "allOf": [
        {
          "type": "string",
          "format": "uri"
        },
        {
          "type": "string",
          "maxLength": 2048,
          "pattern": "^https:\\/\\/"
        }
      ]
    },
    "MCPServerAuthentication": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "bearer"
        },
        "secret": {
          "$ref": "#/$defs/SecretReference"
        }
      },
      "required": [
        "type",
        "secret"
      ],
      "additionalProperties": false
    },
    "SecretReference": {
      "type": "object",
      "properties": {
        "ref": {
          "$ref": "#/$defs/Identifier"
        }
      },
      "required": [
        "ref"
      ],
      "additionalProperties": false
    }
  }
}
