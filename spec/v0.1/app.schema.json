{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://app-spec.ai/spec/v0.1/app.schema.json",
  "title": "AI App Manifest",
  "description": "An AI App Spec version 0.1 manifest.",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "const": "app-spec.ai/v0.1"
    },
    "kind": {
      "const": "App"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "spec": {
      "$ref": "#/$defs/spec"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entrypoint", "resources"],
      "properties": {
        "entrypoint": {
          "$ref": "#/$defs/identifier"
        },
        "resources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/agentResource"
          }
        }
      }
    },
    "agentResource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "instructions"],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "type": {
          "const": "agent"
        },
        "instructions": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

