{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://app-spec.ai/spec/v0.1/app.schema.json",
  "type": "object",
  "properties": {
    "apiVersion": {
      "$ref": "#/$defs/ApiVersion"
    },
    "kind": {
      "$ref": "#/$defs/AppKind"
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "spec": {
      "$ref": "#/$defs/AppSpec"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "additionalProperties": false,
  "title": "AI App Manifest",
  "description": "An AI App Spec version 0.1 manifest.",
  "$defs": {
    "ApiVersion": {
      "type": "string",
      "const": "app-spec.ai/v0.1"
    },
    "AppKind": {
      "type": "string",
      "const": "App"
    },
    "Metadata": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "#/$defs/Identifier"
        },
        "version": {
          "$ref": "#/$defs/SemanticVersion"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "name",
        "version"
      ],
      "additionalProperties": false
    },
    "Identifier": {
      "type": "string",
      "maxLength": 63,
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "SemanticVersion": {
      "type": "string",
      "maxLength": 255,
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "AppSpec": {
      "type": "object",
      "properties": {
        "entrypoint": {
          "$ref": "#/$defs/Identifier"
        },
        "resources": {
          "minItems": 1,
          "type": "array",
          "items": {
            "$ref": "#/$defs/AgentResource"
          }
        }
      },
      "required": [
        "entrypoint",
        "resources"
      ],
      "additionalProperties": false
    },
    "AgentResource": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/$defs/Identifier"
        },
        "type": {
          "type": "string",
          "const": "agent"
        },
        "implementation": {
          "$ref": "#/$defs/AgentImplementation"
        }
      },
      "required": [
        "id",
        "type",
        "implementation"
      ],
      "additionalProperties": false
    },
    "AgentImplementation": {
      "type": "object",
      "properties": {
        "format": {
          "$ref": "#/$defs/ImplementationFormat"
        },
        "package": {
          "$ref": "#/$defs/ImplementationPackage"
        }
      },
      "required": [
        "format",
        "package"
      ],
      "additionalProperties": false
    },
    "ImplementationFormat": {
      "type": "string",
      "maxLength": 255,
      "pattern": "^(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\/[a-z][a-z0-9]*(?:-[a-z0-9]+)*:v(?:0|[1-9]\\d*)(?:\\.(?:0|[1-9]\\d*)){0,2}$"
    },
    "ImplementationPackage": {
      "type": "object",
      "properties": {
        "location": {
          "$ref": "#/$defs/PackageLocation"
        },
        "digest": {
          "$ref": "#/$defs/Sha256Digest"
        }
      },
      "required": [
        "location",
        "digest"
      ],
      "additionalProperties": false
    },
    "PackageLocation": {
      "anyOf": [
        {
          "$ref": "#/$defs/PackageRelativeLocation"
        },
        {
          "$ref": "#/$defs/AbsolutePackageLocation"
        }
      ]
    },
    "PackageRelativeLocation": {
      "type": "string",
      "maxLength": 2048,
      "pattern": "^\\.\\/[A-Za-z0-9](?:[A-Za-z0-9._-]*[A-Za-z0-9])?(?:\\/[A-Za-z0-9](?:[A-Za-z0-9._-]*[A-Za-z0-9])?)*$"
    },
    "AbsolutePackageLocation": {
      "type": "string",
      "maxLength": 2048,
      "pattern": "^(?![Ff][Ii][Ll][Ee]:)(?![A-Za-z]:[\\\\/])[A-Za-z][A-Za-z0-9+.-]*:[^\\s\\\\]+$"
    },
    "Sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
